# ============================================
#  Telegram Userbot Dashboard — Config
# ============================================
#
#  YANG WAJIB DIISI CUMA 2:
#    API_ID dan API_HASH
#
#  SESSION_STRING tidak perlu!
#  Tambah akun lewat web dashboard.
#
# ============================================

# [WAJIB] Telegram API — dapatkan di https://my.telegram.org
# Ini SAMA untuk semua akun, cukup 1 pasang
API_ID=
API_HASH=

# [GANTI] Secret key untuk keamanan login dashboard
SECRET_KEY=ganti-ini-dengan-string-random

# --- Jangan diubah kecuali perlu ---
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
DATABASE_URL=sqlite:///./userbot.db