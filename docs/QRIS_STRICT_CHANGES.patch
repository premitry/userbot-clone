-    else:
-        try:
-            amount_int = parse_amount(str(amount))
-        except Exception:
-            raise ValueError("Format nominal tidak valid. Contoh: /qris 5000 atau /qris 5k")
+        raise ValueError("Format nominal tidak valid. Gunakan angka penuh, contoh: /qris 10000")
+    try:
+        amount_int = parse_amount(amount)  # selalu lewat sini, validasi digit dulu
+    except ValueError as ve:
+        raise ve
+    except Exception:
+        raise ValueError("Format nominal tidak valid. Gunakan angka penuh, contoh: /qris 10000")
+
     if amount_int <= 0:
